{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akta.dev/schemas/vsa_scientific_report.schema.json",
  "title": "VSA ScientificReport (rich claim graph)",
  "type": "object",
  "required": ["report_id"],
  "properties": {
    "report_id": { "type": "string" },
    "id": { "type": "string" },
    "scientific_report_id": { "type": "string" },
    "domain": { "type": "string" },
    "project_id": { "type": "string" },
    "overall_evidence_strength": { "type": "string" },
    "evidence_strength": { "type": "string" },
    "evidence_state": { "type": "string" },
    "validation_status": { "type": "string" },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id"],
        "properties": {
          "claim_id": { "type": "string" },
          "text": { "type": "string" },
          "evidence_level": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "status": { "type": "string" },
          "parent_claim_id": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "evidence_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["link_id", "claim_id"],
        "properties": {
          "link_id": { "type": "string" },
          "claim_id": { "type": "string" },
          "source_type": { "type": "string" },
          "source_ref": { "type": "string" },
          "weight": { "type": "number" }
        },
        "additionalProperties": true
      }
    },
    "validation_results": {
      "type": "object",
      "properties": {
        "literature_supported": { "type": "boolean" },
        "simulation_supported": { "type": "boolean" },
        "preliminary_experimental": { "type": "boolean" },
        "internally_replicated": { "type": "boolean" },
        "independently_replicated": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "disclaimers": { "type": "array", "items": { "type": "string" } },
    "human_review": { "type": ["object", "null"] }
  },
  "additionalProperties": true
}
