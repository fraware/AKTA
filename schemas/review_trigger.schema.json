{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akta.dev/schemas/review_trigger.schema.json",
  "title": "AKTA Review Trigger",
  "type": "object",
  "required": [
    "review_trigger_id",
    "review_trigger_version",
    "decision_id",
    "source_record_id",
    "akta_decision_id",
    "akta_record_id",
    "requested_tool",
    "requested_action",
    "requested_scope",
    "deployment_profile",
    "scientific_action_type",
    "responsibility_level",
    "evidence_state",
    "validation_status",
    "verification_status",
    "admissibility",
    "decision_reason",
    "required_review_role",
    "review_artifacts_required",
    "blocked_tools",
    "allowed_next_steps",
    "approval_effect",
    "default_expiration",
    "policy_hash",
    "tool_registry_hash",
    "review_trigger_hash"
  ],
  "properties": {
    "review_trigger_id": { "type": "string" },
    "review_trigger_version": { "type": "string", "const": "0.3" },
    "decision_id": { "type": "string" },
    "akta_decision_id": { "type": "string" },
    "source_record_id": { "type": "string" },
    "akta_record_id": { "type": "string" },
    "requested_tool": { "type": "string" },
    "requested_action": { "type": "string" },
    "requested_scope": {
      "type": "string",
      "enum": [
        "protocol_draft",
        "active_protocol_update",
        "single_validation_plan",
        "single_validation_run_draft",
        "single_run_queue_priority",
        "robot_queue_submission",
        "execution_payload_preparation",
        "publication_claim",
        "scientific_memory_import"
      ]
    },
    "review_route": { "type": "string" },
    "review_scope": { "type": "string", "deprecated": true },
    "deployment_profile": { "type": "string" },
    "scientific_action_type": { "type": "string" },
    "responsibility_level": { "type": "string" },
    "evidence_state": { "type": "string" },
    "validation_status": { "type": "string" },
    "verification_status": { "type": "string" },
    "admissibility": { "type": "string" },
    "decision_reason": { "type": "string" },
    "required_review_role": { "type": "string" },
    "review_artifacts_required": { "type": "array", "items": { "type": "string" } },
    "blocked_tools": { "type": "array", "items": { "type": "string" } },
    "allowed_next_steps": { "type": "array", "items": { "type": "string" } },
    "approval_effect": { "type": "string" },
    "default_expiration": { "type": "string" },
    "policy_hash": { "type": "string", "pattern": "^sha256:" },
    "tool_registry_hash": { "type": "string", "pattern": "^sha256:" },
    "domain_overlay_hash": { "type": "string", "pattern": "^sha256:" },
    "classifier_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "classification_rationale": { "type": "string" },
    "consequentiality": { "type": "boolean" },
    "consequentiality_reason": { "type": "string" },
    "scientific_context": { "type": "object" },
    "review_trigger_hash": { "type": "string", "pattern": "^sha256:" }
  },
  "additionalProperties": true
}
