{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akta.dev/schemas/akta_decision.schema.json",
  "title": "AKTA Decision",
  "type": "object",
  "required": [
    "decision_id",
    "timestamp",
    "deployment_profile",
    "requested_action",
    "requested_tool",
    "scientific_action_type",
    "responsibility_level",
    "evidence_state",
    "validation_status",
    "verification_status",
    "admissibility",
    "decision_reason",
    "blocked_tools",
    "allowed_tools",
    "next_admissible_steps",
    "record_required",
    "review_required",
    "authorization_required",
    "policy_version",
    "policy_hash"
  ],
  "properties": {
    "decision_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "system_id": { "type": "string" },
    "deployment_profile": { "type": "string" },
    "domain": { "type": "string" },
    "requested_action": { "type": "string" },
    "requested_tool": { "type": "string" },
    "scientific_action_type": { "type": "string" },
    "responsibility_level": { "type": "string" },
    "evidence_state": { "type": "string" },
    "validation_status": { "type": "string" },
    "verification_status": { "type": "string" },
    "admissibility": {
      "type": "string",
      "enum": [
        "allowed",
        "allowed_with_logging",
        "draft_only",
        "review_required",
        "authorization_required",
        "blocked",
        "abstain_insufficient_context"
      ]
    },
    "decision_reason": { "type": "string" },
    "required_review_role": { "type": ["string", "null"] },
    "blocked_tools": { "type": "array", "items": { "type": "string" } },
    "allowed_tools": { "type": "array", "items": { "type": "string" } },
    "next_admissible_steps": { "type": "array", "items": { "type": "string" } },
    "record_required": { "type": "boolean" },
    "review_required": { "type": "boolean" },
    "authorization_required": { "type": "boolean" },
    "policy_version": { "type": "string" },
    "policy_hash": { "type": "string", "pattern": "^sha256:" },
    "domain_overlay_version": { "type": ["string", "null"] },
    "domain_overlay_hash": { "type": ["string", "null"], "pattern": "^sha256:" },
    "tool_registry_hash": { "type": "string", "pattern": "^sha256:" },
    "review_trigger": { "type": ["object", "null"] },
    "classifier_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": true
}
